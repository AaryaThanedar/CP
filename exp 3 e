#include <iostream>
using namespace std;

int countSubsets(int arr[], int n, int sum) {
    if (sum == 0)
        return 1;
    if (n == 0)
        return 0;

    if (arr[n - 1] <= sum)
        return countSubsets(arr, n - 1, sum - arr[n - 1]) + countSubsets(arr, n - 1, sum);
    else
        return countSubsets(arr, n - 1, sum);
}

int main() {
    int n, sum;
    cout << "Enter size of array: ";
    cin >> n;

    int arr[n];
    cout << "Enter array elements: ";
    for (int i = 0; i < n; i++)
        cin >> arr[i];

    cout << "Enter target sum: ";
    cin >> sum;

    cout << "Count of subsets with sum " << sum << " = " << countSubsets(arr, n, sum) << endl;
    return 0;
}
