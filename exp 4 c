#include <iostream>
#include <vector>
using namespace std;

int main() {
    vector<int> arr = {0, 1, 9, 8, 0, 4, 0, 2};
    int n = arr.size();

    int index = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] != 0)
            arr[index++] = arr[i];
    }
    while (index < n)
        arr[index++] = 0;

    for (int x : arr)
        cout << x << " ";
}
