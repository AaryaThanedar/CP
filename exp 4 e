#include <iostream>
#include <vector>
using namespace std;

int main() {
    vector<int> arr = {16, 17, 4, 3, 5, 2};
    int n = arr.size();

    vector<int> leaders;
    int maxRight = arr[n-1];
    leaders.push_back(maxRight);

    for (int i = n-2; i >= 0; i--) {
        if (arr[i] >= maxRight) {
            maxRight = arr[i];
            leaders.push_back(arr[i]);
        }
    }

    for (int i = leaders.size()-1; i >= 0; i--)
        cout << leaders[i] << " ";
}
