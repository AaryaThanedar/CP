#include <iostream>
#include <vector>
using namespace std;

int main() {
    
    vector<int> arr = {15, 11, 27, 8, 12};
    int tableSize = 7;

  
    vector<vector<int>> hashTable(tableSize);

    
    for (int key : arr) {
        int index = key % tableSize;
        hashTable[index].push_back(key);
    }

   
    for (int i = 0; i < tableSize; i++) {
        cout << i << " --> ";
        for (int val : hashTable[i]) {
            cout << val << " ";
        }
        cout << endl;
    }

    return 0;
}
