#include <iostream>
using namespace std;

int binarySearch(int arr[], int low, int high, int target) {
    if (low > high) return -1;
    int mid = (low + high) / 2;

    if (arr[mid] == target) {
        cout << "Found " << target << " at index " << mid << endl;
        target *= 3;  
        return binarySearch(arr, 0, high, target); 
    }
    else if (arr[mid] < target) return binarySearch(arr, mid + 1, high, target);
    else return binarySearch(arr, low, mid - 1, target);
}

int main() {
    int arr[] = {2, 6, 18, 54, 162, 486};
    int n = sizeof(arr)/sizeof(arr[0]);
    int target = 6;

    int result = binarySearch(arr, 0, n - 1, target);

    if (result == -1) cout << "Final target not found" << endl;

    return 0;
}
