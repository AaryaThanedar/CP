#include <iostream>
using namespace std;

int lastOccurrence(int arr[], int n, int x) {
    int low = 0, high = n - 1;
    int result = -1;  // Default if not found

    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (arr[mid] == x) {
            result = mid;   // Possible answer
            low = mid + 1;  // Keep searching on the right side
        }
        else if (arr[mid] < x) {
            low = mid + 1;
        }
        else {
            high = mid - 1;
        }
    }
    return result;
}

int main() {
    int arr[] = {1, 2, 4, 4, 4, 5, 7, 9};
    int n = sizeof(arr) / sizeof(arr[0]);
    int x = 4;

    int index = lastOccurrence(arr, n, x);

    if (index != -1)
        cout << "Last occurrence of " << x << " is at index " << index << endl;
    else
        cout << x << " not found in array." << endl;

    return 0;
}
