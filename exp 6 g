#include <iostream>
using namespace std;

void findPair(int arr[], int n, int target) {
    int left = 0, right = n - 1;
    bool found = false;

    while (left < right) {
        int sum = arr[left] + arr[right];

        if (sum == target) {
            cout << "Pair found: (" << arr[left] << ", " << arr[right] << ")" << endl;
            found = true;
            left++;   // Move left pointer
            right--;  // Move right pointer
        }
        else if (sum < target) {
            left++;   // Increase sum
        }
        else {
            right--;  // Decrease sum
        }
    }

    if (!found) {
        cout << "No pair found with sum " << target << endl;
    }
}

int main() {
    int arr[] = {1, 2, 3, 4, 7, 11, 15};
    int n = sizeof(arr) / sizeof(arr[0]);
    int target = 15;

    findPair(arr, n, target);

    return 0;
}
