#include <iostream>
#include <vector>
#include <algorithm>  // for sort()

using namespace std;

int main() {
    vector<int> v = {5, 2, 9, 1, 5, 6};

    // Sort in ascending order
    sort(v.begin(), v.end());

    cout << "Sorted vector (ascending): ";
    for (int x : v) {
        cout << x << " ";
    }
    cout << endl;

    // Sort in descending order
    sort(v.begin(), v.end(), greater<int>());

    cout << "Sorted vector (descending): ";
    for (int x : v) {
        cout << x << " ";
    }
    cout << endl;

    return 0;
}
