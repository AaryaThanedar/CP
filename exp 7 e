#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    vector<int> v1 = {1, 2, 4, 5, 6};
    vector<int> v2 = {2, 4, 6, 8};

    sort(v1.begin(), v1.end());
    sort(v2.begin(), v2.end());

    vector<int> intersection;
    int i = 0, j = 0;

    while (i < v1.size() && j < v2.size()) {
        if (v1[i] == v2[j]) {
            intersection.push_back(v1[i]);
            i++;
            j++;
        }
        else if (v1[i] < v2[j]) {
            i++;
        }
        else {
            j++;
        }
    }

    cout << "Intersection: ";
    for (int x : intersection) {
        cout << x << " ";
    }
    cout << endl;

    return 0;
}
