#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    vector<int> v = {50, 10, 40, 20, 30, 60};
    vector<int> keys = {0, 2, 4};
    vector<int> result;

    sort(v.begin(), v.end());

    for (int k : keys) {
        if (k >= 0 && k < v.size()) {
            result.push_back(v[k]);
        }
    }

    for (int x : result) {
        cout << x << " ";
    }
    cout << endl;

    return 0;
}
