#include <iostream>
#include <stack>
using namespace std;

int main() {
    string s;
    cin >> s;

    stack<char> st;
    int flag = 1;

    for (char c : s) {
        if (c == '(' || c == '{' || c == '[') {
            st.push(c);
        } else {
            if (st.empty()) {
                flag = 0;
                break;
            }
            char t = st.top();
            st.pop();

            if ((c == ')' && t != '(') ||
                (c == '}' && t != '{') ||
                (c == ']' && t != '[')) {
                flag = 0;
                break;
            }
        }
    }

    if (!st.empty()) flag = 0;

    if (flag) cout << "Balanced";
    else cout << "Not Balanced";

    return 0;
}
