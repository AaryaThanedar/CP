#include <iostream>
using namespace std;

long long power(long long m, long long n) {
    long long result = 1;
    while (n > 0) {
        if (n % 2 == 1) result *= m;
        m *= m;
        n /= 2;
    }
    return result;
}

int main() {
    long long m, n;
    cin >> m >> n;

    cout << power(m, n);
    return 0;
}
