#include <iostream>
#include <vector>
#include <numeric>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<long long> fib;
    fib.push_back(0);
    if (n > 1) fib.push_back(1);

    partial_sum(fib.begin(), fib.end(), fib.begin());

    for (int i = 2; i < n; i++) {
        fib.push_back(fib[i - 1] + fib[i - 2]);
    }

    for (auto x : fib) cout << x << " ";

    return 0;
}
