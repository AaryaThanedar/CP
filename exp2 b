#include <iostream>
using namespace std;

int main() {
    int num, n;

    cout << "Enter number: ";
    cin >> num;

    cout << "Enter bit position (0-based): ";
    cin >> n;

    int mask = 1 << n;

    cout << "Binary of number: ";
    for (int i = 31; i >= 0; i--) {
        cout << ((num >> i) & 1);
    }
    cout << endl;

    if (num & mask)
        cout << "Bit at position " << n << " is SET (1)" << endl;
    else
        cout << "Bit at position " << n << " is NOT SET (0)" << endl;

    return 0;
}
