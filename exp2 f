#include <iostream>
using namespace std;

int main() {
    int arr[] = {1, 2, 3, 2, 3, 1, 3, 5, 5, 5};
    int n = sizeof(arr) / sizeof(arr[0]);

    for (int i = 0; i < n; i++) {
        int count = 0;
        for (int j = 0; j < n; j++) {
            if (arr[i] == arr[j]) count++;
        }
        if (count % 2 != 0) {
            int result = arr[i];
            cout << result << " ";
            
            for (int j = i + 1; j < n; j++) {
                if (arr[i] == arr[j]) arr[j] = 0;
            }
        }
    }
    cout << endl;
    return 0;
}
